rules_version = '2';

// auth.token.email is the email of the authenticated user
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is an admin in Firestore
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email != null &&
             firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email.lower()));
    }

    // Helper function to check if a user can read a specific admin background
    function canReadAdminBackground(backgroundId) {
      let background = firestore.get(/databases/(default)/documents/admin_backgrounds/$(backgroundId));
      return request.auth != null && (
               isAdmin() ||
               background.data.accessLevel == "public" ||
               (
                 background.data.accessLevel == "beta" && 
                 request.auth.token.email.lower() in background.data.betaUsers
               )
             );
    }

    match /users/{userId}/backgrounds/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/screenshots/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/stickers/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/display_images/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/hotspot_images/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/instructional/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/notebooks/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/pdfs/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /admin_backgrounds/{backgroundId}/{fileName} {
      allow read: if canReadAdminBackground(backgroundId);
      allow write: if isAdmin();
    }

    match /admin_weather/{rangeId}/{fileName} {
      allow read: if true; // Weather images are public
      allow write: if isAdmin();
    }

    match /admin_stickers/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_catalyst_icons/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /catalyst/images/{routineId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_music_thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_logos/{fileName} {
      allow read: if true; // Logo should be public for all users
      allow write: if isAdmin();
    }

    // Global PDFs — all authenticated users can read, only admins can write
    match /global_pdfs/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Activity Wall Photos — students upload once (create only); teachers view via
    // download URLs that include an unguessable download token managed by Firebase
    // Storage (not a Firebase Auth token). These token-based URLs are not subject to
    // these rules, so <img> display works without SDK read permission.
    // SDK-level read/list is limited to the owning teacher and admins.
    match /activity_wall_photos/{sessionId}/{fileName} {
      // Only the teacher who owns the session (sessionId prefix = their uid) or an admin
      // can list/download via the SDK.
      allow read: if request.auth != null &&
        (isAdmin() || sessionId.matches(request.auth.uid + '_.*'));
      // Any authenticated user (including anonymous students) may upload a new image,
      // but only if the target session exists in Firestore (guards against DoS uploads
      // to guessed sessionIds).
      allow create: if request.auth != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*') &&
        firestore.exists(
          /databases/(default)/documents/activity_wall_sessions/$(sessionId)
        );
      // The owning teacher/admin may delete the temporary Firebase copy after Drive archival.
      allow delete: if request.auth != null &&
        (isAdmin() || sessionId.matches(request.auth.uid + '_.*'));
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
