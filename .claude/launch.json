{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-dev",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "vite-dev-bypass",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-Command",
        "$env:VITE_AUTH_BYPASS='true'; pnpm run dev -- --port 56300 --strictPort"
      ],
      "port": 56300
    },
    {
      "name": "functions-emulator",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-C", "functions", "run", "serve"],
      "port": 5001
    }
  ]
}
